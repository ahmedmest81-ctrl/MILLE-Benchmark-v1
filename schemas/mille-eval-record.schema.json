{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wellyes1-millie.hf.space/schemas/mille-eval-record.schema.json",
  "title": "MILLE Eval Dataset Record",
  "description": "JSONL record contract for benchmark and dataset publishing.",
  "type": "object",
  "required": ["id", "prompt", "task", "expected_blueprint", "rubric", "failure_modes"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "prompt": { "type": "string", "minLength": 3 },
    "task": {
      "type": "string",
      "enum": ["classification", "regression", "forecasting", "recommendation", "clustering", "anomaly_detection", "multi_component_system"]
    },
    "domain": { "type": "string" },
    "input_schema": {
      "type": "object",
      "additionalProperties": true
    },
    "dataset_profile": {
      "anyOf": [
        { "$ref": "./mille-dataset-profile.schema.json" },
        { "type": "null" }
      ]
    },
    "expected_blueprint": { "$ref": "./mille-blueprint.schema.json" },
    "rubric": {
      "type": "object",
      "required": ["must_have", "should_have"],
      "additionalProperties": true,
      "properties": {
        "must_have": {
          "type": "array",
          "items": { "type": "string" }
        },
        "should_have": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scoring_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "failure_modes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
