{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wellyes1-millie.hf.space/schemas/mille-dataset-profile.schema.json",
  "title": "MILLE Dataset Profile",
  "description": "Stable public contract for the lightweight CSV profiler used by MILLE.",
  "type": "object",
  "required": [
    "filename",
    "delimiter",
    "row_count",
    "column_count",
    "columns",
    "inferred",
    "executable_checks",
    "target_candidates",
    "leakage_warnings",
    "quality_warnings"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Optional explicit schema version. Missing means v1 for legacy outputs.",
      "default": "1.0.0"
    },
    "filename": { "type": "string" },
    "delimiter": { "type": "string" },
    "row_count": { "type": "integer", "minimum": 0 },
    "column_count": { "type": "integer", "minimum": 0 },
    "columns": {
      "type": "array",
      "items": { "$ref": "#/$defs/columnProfile" }
    },
    "inferred": { "$ref": "#/$defs/inferredDataset" },
    "executable_checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/executableCheck" }
    },
    "target_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "score"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string" },
          "score": { "type": "number" }
        }
      }
    },
    "leakage_warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "quality_warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    }
  },
  "$defs": {
    "columnProfile": {
      "type": "object",
      "required": [
        "name",
        "index",
        "kind",
        "missing_count",
        "missing_ratio",
        "unique_count",
        "unique_ratio",
        "non_missing_count",
        "sample_values"
      ],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "index": { "type": "integer", "minimum": 0 },
        "kind": {
          "type": "string",
          "enum": ["numeric", "categorical", "text", "date", "id", "boolean", "empty"]
        },
        "missing_count": { "type": "integer", "minimum": 0 },
        "missing_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "unique_count": { "type": "integer", "minimum": 0 },
        "unique_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "non_missing_count": { "type": "integer", "minimum": 0 },
        "sample_values": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "inferredDataset": {
      "type": "object",
      "required": [
        "target",
        "task_type",
        "id_columns",
        "date_columns",
        "numeric_features",
        "categorical_features",
        "text_features",
        "excluded_features"
      ],
      "additionalProperties": true,
      "properties": {
        "target": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "task_type": {
          "type": "string",
          "enum": ["classification", "regression", "forecasting", "recommendation", "clustering"]
        },
        "id_columns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "date_columns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "numeric_features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "categorical_features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "text_features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excluded_features": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "executableCheck": {
      "type": "object",
      "required": ["kind", "executable_consequence"],
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string" },
        "evaluated_rows": { "type": "integer", "minimum": 0 },
        "evaluated_transitions": { "type": "integer", "minimum": 0 },
        "executable_consequence": { "type": "string" }
      }
    },
    "warning": {
      "type": "object",
      "required": ["column", "severity", "reason"],
      "additionalProperties": true,
      "properties": {
        "column": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["info", "warn", "block"]
        },
        "reason": { "type": "string" }
      }
    }
  }
}
