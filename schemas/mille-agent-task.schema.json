{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wellyes1-millie.hf.space/schemas/mille-agent-task.schema.json",
  "title": "MILLE Agent Task",
  "description": "Input contract for agents calling MILLE through HTTP, MCP, or an SDK wrapper.",
  "type": "object",
  "required": ["idea"],
  "additionalProperties": false,
  "properties": {
    "idea": {
      "type": "string",
      "minLength": 3,
      "description": "Plain-language ML system request."
    },
    "task": {
      "type": "string",
      "default": "auto",
      "enum": ["auto", "classification", "regression", "forecasting", "recommendation", "clustering"]
    },
    "audience": {
      "type": "string",
      "default": "technical",
      "enum": ["technical", "business", "executive"]
    },
    "dataset_profile": {
      "anyOf": [
        { "$ref": "./mille-dataset-profile.schema.json" },
        { "type": "null" }
      ]
    },
    "dataset_csv": {
      "type": "string",
      "description": "Optional CSV text for export endpoints that include sample data."
    },
    "dataset_filename": {
      "type": "string",
      "description": "Optional original filename for dataset CSV payloads."
    },
    "gate_answers": {
      "type": "object",
      "description": "Optional user answers for resolving or accepting MILLE consequence gates.",
      "additionalProperties": true,
      "properties": {
        "false_negative_cost": { "type": "number" },
        "false_positive_cost": { "type": "number" },
        "minimum_recall": { "type": "number", "minimum": 0, "maximum": 1 },
        "cutoff_date": { "type": "string" },
        "prediction_horizon": { "type": "string" },
        "input_validation_acknowledged": { "type": "boolean" },
        "leakage_field_known_before_prediction": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "accepted_gate_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
